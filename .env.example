# Required: Telegram bot token from @BotFather
BOT_TOKEN=

# Optional: Anthropic API key (if unset, uses your Claude Code subscription)
# ANTHROPIC_API_KEY=

# Required: Comma-separated Telegram chat IDs allowed to use the bot
ALLOWED_CHAT_IDS=

# Optional: Max agentic turns per message (default: 30)
AGENT_MAX_TURNS=30

# Optional: Agent timeout in milliseconds (default: 900000 = 15 minutes)
AGENT_TIMEOUT_MS=900000

# Optional: Working directory for Claude (default: home directory)
AGENT_CWD=

# Optional: PIN lock — generate hash with: bun run scripts/hash-pin.ts <your-pin>
# Omit PIN_HASH to disable PIN locking entirely
PIN_HASH=
PIN_SALT=

# Optional: Auto-lock after N minutes of inactivity (default: 30)
IDLE_LOCK_MINUTES=30

# Memory: fact extraction runs on Groq (GROQ_API_KEY above — same key as Whisper STT).
# Embeddings run locally via @huggingface/transformers (no API key).
# Without GROQ_API_KEY, memory features are disabled — bot works normally without it.
